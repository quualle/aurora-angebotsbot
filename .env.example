# Aurora Angebots-Bot — benoetigte Secrets (Beispiel; KEINE echten Werte committen!)
# Hinterlegt werden sie als Supabase Edge Secrets ODER in Tabelle angebotsworkflow_secrets
# (Keys dort: secret_openrouter_api_key, secret_voyage_api_key, secret_sevdesk_api_token,
#  secret_telegram_bot_token, secret_telegram_webhook_secret, secret_admin_key).

OPENROUTER_API_KEY=sk-or-...        # Chat (GPT-5.5), Transkription, Vision, PDF
VOYAGE_API_KEY=pa-...               # Embeddings (voyage-4-large)
SEVDESK_API_TOKEN=...               # Aurora sevDesk (Angebote)
TELEGRAM_BOT_TOKEN=123456:ABC...    # @Aurorahaus_bot
TELEGRAM_WEBHOOK_SECRET=<random>    # Schutz des Webhooks (frei waehlbar)
ADMIN_KEY=<random>                  # Admin-Endpunkte (whoami/setwebhook/test)

# Optional
TELEGRAM_ALLOWED_USER_IDS=111111,222222   # zusaetzlich zur Whitelist-Tabelle
EMBED_MODEL=voyage-4-large

# Auto-injiziert von Supabase (nicht selbst setzen):
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
